{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "nix": {
    "enabled": true
  },
  "customManagers": [
    {
      "customType": "regex",
      "fileMatch": ["modules/agents/.*\\.nix$"],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>[a-z-]+) depName=(?<depName>[^\\s]+)\\n\\s*# version: (?<currentValue>[^\\s]+)"
      ],
      "versioningTemplate": "semver"
    }
  ],
  "packageRules": [
    {
      "matchManagers": ["nix"],
      "matchPackageNames": ["nixpkgs"],
      "commitMessageExtra": "({{{newVersion}}})"
    },
    {
      "matchManagers": ["nix"],
      "matchPackageNames": ["microvm"]
    },
    {
      "matchManagers": ["custom.regex"],
      "groupName": "ai agent tools"
    }
  ]
}
